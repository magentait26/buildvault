APP_NAME=BuildVault
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://docs.bhoomione.in

# Cryptographic key (Generate with: php artisan key:generate)
APP_KEY=SomeSecretBase64EncodedKeyGoesHere=

# Log Configuration
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Production Relational Database Parameters (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=buildvault-db
DB_PORT=5432
DB_DATABASE=buildvault_prod
DB_USERNAME=buildvault_admin
DB_PASSWORD=vault_secure_password_993

# Cache and Sessions (Redis or simple database fallback)
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true # Secure cookies only on production SSL
SESSION_DOMAIN=.bhoomione.in

# Sanctum State Configurations
SANCTUM_STATEFUL_DOMAINS=docs.bhoomione.in,localhost

# Filesystem and Blob Storage (Local first, S3 ready)
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=buildvault-s3-prod
AWS_USE_PATH_STYLE_ENDPOINT=false

# MFA and Systems constraints defaults
ENABLE_MFA=true
DEFAULT_FILE_SIZE_LIMIT_MB=50
